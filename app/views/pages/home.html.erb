  function showLocationDetails(locationName) {
    // Vérifier si c'est une région
    for (const regionId in regionsData) {
      if (regionsData[regionId].name === locationName) {
        currentRegion = regionId;
        updateRegionInfo(regionId);
        showRegionPanel();
        highlightRegionOnMap(regionId);
        return;
      }
    }
    
    // Vérifier si c'est un district
    for (const regionId in regionsData) {
      const region = regionsData[regionId];
      if (region.districts) {
        const district = region.districts.find(d => d.name === locationName);
        if (district) {
          currentRegion = regionId;
          currentDistrict = locationName;
          showDistrictsPanel(regionId);
          focusOnDistrict(regionId, locationName);
          return;
        }
      }
    }
    
    // Vérifier si c'est une commune
    for (const regionId in regionsData) {
      const region = regionsData[regionId];
      if (region.districts) {
        for (const district of region.districts) {
          if (district.communes) {
            const commune = district.communes.find(c => c.name === locationName);
            if (commune) {
              currentRegion = regionId;
              currentDistrict = district.name;
              currentCommune = locationName;
              showCommunesPanel(regionId, district.name);
              focusOnCommune(regionId, district.name, locationName);
              return;
            }
          }
        }
      }
    }
    
    // Vérifier si c'est un fokontany
    for (const regionId in regionsData) {
      const region = regionsData[regionId];
      if (region.districts) {
        for (const district of region.districts) {
          if (district.communes) {
            for (const commune of district.communes) {
              if (commune.fokontany) {
                const fokontany = commune.fokontany.find(f => f.name === locationName);
                if (fokontany) {
                  currentRegion = regionId;
                  currentDistrict = district.name;
                  currentCommune = commune.name;
                  currentFokontany = locationName;
                  showFokontanyPanel(regionId, district.name, commune.name);
                  focusOnFokontany(regionId, district.name, commune.name, locationName);
                  return;
                }
              }
            }
          }
        }
      }
    }
  }
