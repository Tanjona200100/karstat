<!-- Sidebar -->
 <div class="sidebar">
      <%= image_tag 'logo.png', alt: 'Votre Logo', width: '70', height: '70'%>  

  <div class="sidebar-item active">
    <i class="bi bi-map sidebar-icon active" data-target="panel1" title="Carte"></i>
    <p>Karstat</p>
  </div>

  <div class="sidebar-item">
    <i class="bi bi-sliders sidebar-icon" data-target="panel2" title="Filtres"></i>
    <p>Filtres</p>
  </div>

  <div class="sidebar-item">
    <i class="bi bi-layout-text-window sidebar-icon" data-target="panel3" title="Affichage"></i>
    <p>Affichage</p>
  </div>

  <div class="sidebar-item">
    <i class="bi bi-box-arrow-right sidebar-icon" title="Déconnexion"></i>
    <p>Quitter</p>
  </div>
</div>
<!-- Main Panel -->
<div class="main-panel">
  <div class="main-scroll">
    <!-- Panel 1: Vue Région -->
    <div class="panel-content active" id="region-panel">
      <h4 class="section-title-head">Vue d'ensemble</h4>
      <p class="sub-title-head">Statistiques globales</p>
      
      <div class="stat-section">
        <div class="stat-box">
          <i class="bi bi-person-check sidebar-icon fs-5"></i>
          <div class="text-muted">Producteurs recensés</div>
          <h5>1 254 000</h5>
          <p>personnes</p>
        </div>
        <div class="stat-box">
          <i class="bi bi-geo-alt sidebar-icon fs-5"></i>
          <div class="text-muted">Parcelles recensées</div>
          <h5>27 540</h5>
          <p>unités</p>
        </div>
        <div class="stat-box">
          <i class="bi bi-app sidebar-icon fs-5"></i>
          <div class="text-muted">Surfaces recensées</div>
          <h5>480 570</h5>
          <p>hectares</p>
        </div>
      </div>

      <p class="sub-title-body">Statistiques par régions</p>

      <!-- Sélecteur de région -->
      <div class="mb-3">
        <select id="region-select" class="form-select">
          <option value="">Sélectionnez une région</option>
        </select>
      </div>

      <div class="region-box">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div class="region-title" id="region-name">Nom région</div>
          <span class="badge bg-light text-muted" id="region-area">0 km²</span>
        </div>
        <table>
          <tr>
              <td>Population : </td>
              <th id="region-population">0 habitants</th>
          </tr>
          <tr>
              <td>Producteurs : </td>
              <th id="region-producers">0</th>
          </tr>
          <tr>
              <td>Parcelles : </td>
              <th id="region-plots">0 unités - 0 ha</th>
          </tr>
          <tr>
              <td>Rizicole : </td>
              <th id="region-rice">0 ha</th>
          </tr>
          <tr>
              <td>Production : </td>
              <th id="region-production">0 tonnes</th>
          </tr>
          <tr>
              <td>Rendement : </td>
              <th id="region-yield">0 kg/ha</th>
          </tr>
          <tr>
              <td>Exploitants : </td>
              <th id="region-farmers">0</th>
          </tr>
        </table>
        <div class="region-meta"><span class="text-end"></span></div>
        <button class="btn-custom" id="view-districts-btn"><i class="bi bi-eye"></i>Voir les districts</button>
        <button class="btn-custom" id="view-on-map-btn"><i class="bi bi-map"></i>Voir sur la carte</button>
      </div>
    </div>

    <!-- Panel 2: Vue Districts -->
    <div class="panel-content" id="districts-panel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="section-title-head" id="districts-region-name">Districts de Menabe</h4>
        <button class="btn-back" id="back-to-region-btn"><i class="bi bi-arrow-left"></i> Retour</button>
      </div>
      
      <div class="districts-container" id="districts-list">
        <!-- Les districts seront ajoutés dynamiquement ici -->
      </div>
    </div>

    <!-- Panel 3: Vue Communes -->
    <div class="panel-content" id="communes-panel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="section-title-head" id="communes-district-name">Communes de Belo sur Tsiribihina</h4>
        <button class="btn-back" id="back-to-districts-btn"><i class="bi bi-arrow-left"></i> Retour</button>
      </div>
      
      <div class="communes-container" id="communes-list">
        <!-- Les communes seront ajoutées dynamiquement ici -->
      </div>
    </div>

    <!-- Panel 4: Vue Fokontany -->
    <div class="panel-content" id="fokontany-panel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="section-title-head" id="fokontany-commune-name">Fokontany de Belo sur Tsiribihina Ville</h4>
        <button class="btn-back" id="back-to-communes-btn"><i class="bi bi-arrow-left"></i> Retour</button>
      </div>
      
      <div class="fokontany-container" id="fokontany-list">
        <!-- Les fokontany seront ajoutés dynamiquement ici -->
      </div>
    </div>
  </div>
</div>

<!-- Map panel -->
<div class="map-panel">
  <div id="map" style="width: 100%; height: 700px;"></div>
</div>

