function showFokontanyPanel(regionId, districtName, communeName) {
    const region = regionsData[regionId];
    if (!region || !region.districts) return;

    // Trouver le district et la commune sélectionnés
    const district = region.districts.find(d => d.name === districtName);
    if (!district || !district.communes) return;

    const commune = district.communes.find(c => c.name === communeName);
    if (!commune || !commune.fokontany) return;

    currentCommune = communeName;

    // Mettre à jour le titre
    document.getElementById('fokontany-commune-name').textContent = `Fokontany de ${communeName}`;
    
    // Remplir la liste des fokontany
    const fokontanyList = document.getElementById('fokontany-list');
    fokontanyList.innerHTML = '';

    commune.fokontany.forEach(fokontany => {
        const isSelectableFokontany = districtName === "BELO SUR TSIRIBIHINA" && 
                                    communeName === "Belo sur Tsiribihina Ville" && 
