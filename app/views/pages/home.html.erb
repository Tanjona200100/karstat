  document.addEventListener("DOMContentLoaded", function() {
    // Initialiser la carte
    initMap();
    
    // Initialiser l'interface
    initUI();
  });

  function initMap() {
    // Centrer sur Madagascar
    map = L.map('map').setView([-19.0, 47.5], 6);

    // Ajouter la couche de tuiles
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    // Charger les données GeoJSON
    loadGeoJsonData();

    // Ajouter des marqueurs de démonstration
    addDemoMarkers();
  }

  // Fonction pour charger les données GeoJSON
  function loadGeoJsonData() {
    fetch('<%= geojson_data_path %>')  // Call your Rails endpoint
      .then(response => response.json())
      .then(data => {
            // Supprimer la couche précédente si elle existe
            if (geoJsonLayer) {
                map.removeLayer(geoJsonLayer);
            }

            // Ajouter la nouvelle couche GeoJSON avec les bons comportements
            geoJsonLayer = L.geoJSON(data, {
                style: function (feature) {
                    return {
                          fillColor: "#e57373",  // rose clair
                          color: "#111",         // NOIR intense pour la délimitation
                          weight: 1,           // épaisseur de trait plus visible
                          opacity: 1,
                          fillOpacity: 0.2
                    };
                },
                onEachFeature: function (feature, layer) {
                    const regionName = feature.properties.name;
                    const regionId = regionName.toLowerCase().replace(/ /g, '-');
                    
                    // Stocker la référence du polygone
                    regionPolygons[regionId] = layer;
                    
                    layer.on({
                        mouseover: function (e) {
                            var layer = e.target;
                            layer.setStyle({
                                fillColor: "#ffff00", // Jaune
                                weight: 1,
                                fillOpacity: 0.5
                            });
                            layer.bindTooltip(feature.properties.name, {
                                permanent: false,
                                direction: "center",
                                className: "region-badge"
                            }).openTooltip();
                        },
                        mouseout: function (e) {
                            geoJsonLayer.resetStyle(e.target);
                            e.target.closeTooltip();
                        },
                        click: function (e) {
                            // Popup moderne (badge)
                            layer.bindPopup(`
                              <div class="region-badge-popup">
                                  <div class="region-badge">${feature.properties.name}</div>
                              </div>
                            `, { className: 'custom-leaflet-popup' }).openPopup();
                            
                            // Mettre à jour l'interface
                            const regionId = feature.properties.name.toLowerCase().replace(/ /g, '-');
                            updateRegionInfo('menabe'); // Ici on utilise 'menabe' car c'est la seule région dans nos données
                            document.getElementById('region-select').value = regionId;
                            currentRegion = regionId;
                        }
                    });
                }
            }).addTo(map);

            // Adapter la vue de la carte à la couche chargée
            map.fitBounds(geoJsonLayer.getBounds());
        })
        .catch(error => console.error('Erreur lors du chargement des données :', error));
  }

  function initUI() {
    // Remplir le sélecteur de régions
    const regionSelect = document.getElementById('region-select');
    for (const regionId in regionsData) {
      const option = document.createElement('option');
      option.value = regionId;
      option.textContent = regionsData[regionId].name;
      regionSelect.appendChild(option);
    }

    // Écouter les changements de sélection de région
    regionSelect.addEventListener('change', function() {
      const selectedRegion = this.value;
      if (selectedRegion) {
        currentRegion = selectedRegion;
        updateRegionInfo(selectedRegion);
        highlightRegionOnMap(selectedRegion);
      }
    });

    // Bouton "Voir les districts"
    document.getElementById('view-districts-btn').addEventListener('click', function() {
      if (currentRegion) {
        showDistrictsPanel(currentRegion);
      }
    });

    // Bouton "Voir sur la carte"
    document.getElementById('view-on-map-btn').addEventListener('click', function() {
      if (currentRegion && regionPolygons[currentRegion]) {
        map.fitBounds(regionPolygons[currentRegion].getBounds());
        highlightRegionOnMap(currentRegion);
      }
    });

    // Bouton "Retour" depuis les districts
    document.getElementById('back-to-region-btn').addEventListener('click', function() {
      showRegionPanel();
      if (currentRegion) {
        highlightRegionOnMap(currentRegion);
      }
    });

    // Bouton "Retour" depuis les communes
    document.getElementById('back-to-districts-btn').addEventListener('click', function() {
      showDistrictsPanel(currentRegion);
      if (currentDistrict) {
        focusOnDistrict(currentRegion, currentDistrict);
      }
    });

    // Bouton "Retour" depuis les fokontany
    document.getElementById('back-to-communes-btn').addEventListener('click', function() {
      showCommunesPanel(currentRegion, currentDistrict);
      if (currentCommune) {
        focusOnCommune(currentRegion, currentDistrict, currentCommune);
      }
    });
  }

  function updateRegionInfo(regionId) {
    const region = regionsData[regionId];
    if (region) {
      document.getElementById('region-name').textContent = region.name;
      document.getElementById('region-area').textContent = region.area;
      document.getElementById('region-population').textContent = region.population + " habitants";
      document.getElementById('region-producers').textContent = region.producers;
      document.getElementById('region-plots').textContent = region.plots;
      document.getElementById('region-rice').textContent = region.rice;
      document.getElementById('region-production').textContent = region.production;
      document.getElementById('region-yield').textContent = region.yield;
      document.getElementById('region-farmers').textContent = region.farmers;
    }
  }

  function highlightRegionOnMap(regionId) {
    // Réinitialiser tous les styles
    if (geoJsonLayer) {
      geoJsonLayer.eachLayer(function(layer) {
        layer.setStyle({
          fillColor: "#e57373",
          fillOpacity: 0.2
        });
      });
    }

    // Mettre en évidence la région sélectionnée
    if (regionPolygons[regionId]) {
      regionPolygons[regionId].setStyle({
        fillColor: "#ff0000",
        fillOpacity: 0.5
      });
      map.fitBounds(regionPolygons[regionId].getBounds());
    }
  }

